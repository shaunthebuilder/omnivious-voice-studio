# Copy this file to `.env` locally when you need to override defaults.
# `.env.example` is the only environment file that belongs in version control.

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8001

# Backend
OMNIVIOUS_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
OMNIVIOUS_DATABASE_URL=sqlite:///./data/omnivious.db
OMNIVIOUS_TTS_RETENTION_HOURS=24
OMNIVIOUS_CLEANUP_INTERVAL_SECONDS=1800
OMNIVIOUS_TTS_MODEL_PREVIEW=mlx-community/chatterbox-turbo-fp16
OMNIVIOUS_TTS_MODEL_FINAL=mlx-community/chatterbox-fp16
OMNIVIOUS_STT_MODEL_ID=mlx-community/Qwen3-ASR-1.7B-8bit
OMNIVIOUS_CLONE_CONDITION_TARGET_SECONDS=45
OMNIVIOUS_CLONE_CONDITION_MIN_SECONDS=20
OMNIVIOUS_CLONE_CONDITION_MAX_SECONDS=60
OMNIVIOUS_ANCHOR_MIN_SECONDS=8
OMNIVIOUS_ANCHOR_MAX_SECONDS=15
OMNIVIOUS_CERTIFICATION_MAX_ANCHORS=4
OMNIVIOUS_CERTIFICATION_REQUIRED_SIMILARITY=0.58
OMNIVIOUS_CERTIFICATION_MIN_OPERATIONAL_RATIO=0.75
OMNIVIOUS_REASONER_MODE=single_pass
OMNIVIOUS_REASONER_DISFLUENCY_LEVEL=moderate
OMNIVIOUS_MLX_REASONING_MODEL=Qwen/Qwen3-4B-MLX-8bit
OMNIVIOUS_TAG_MAX_PER_SENTENCE=1
OMNIVIOUS_TAG_MAX_TOTAL=8
OMNIVIOUS_LLM_EDIT_BUDGET_RATIO=0.12
OMNIVIOUS_LLM_OUTPUT_GROWTH_CAP_RATIO=1.15
OMNIVIOUS_SYNTH_TIMEOUT_SECONDS=90
OMNIVIOUS_CERTIFICATION_SYNTH_TIMEOUT_SECONDS=45
OMNIVIOUS_SEGMENT_TARGET_CHARS=170
OMNIVIOUS_SEGMENT_MAX_CHARS=260
OMNIVIOUS_SEGMENT_CROSSFADE_MS=26
OMNIVIOUS_SEGMENT_BASE_PAUSE_MS=120
OMNIVIOUS_PREVIEW_RENDER_MAX_TOKENS=520
OMNIVIOUS_FINAL_RENDER_MAX_TOKENS=880
OMNIVIOUS_JOB_STALE_TIMEOUT_SECONDS=600
OMNIVIOUS_JOB_WATCHDOG_INTERVAL_SECONDS=60
OMNIVIOUS_IDENTITY_STRICT_PASS_THRESHOLD=0.70
OMNIVIOUS_IDENTITY_WARNING_FLOOR=0.50
OMNIVIOUS_IDENTITY_HARD_FAIL_FLOOR=0.35

# All `data/*` paths are local runtime state and should not be committed.
